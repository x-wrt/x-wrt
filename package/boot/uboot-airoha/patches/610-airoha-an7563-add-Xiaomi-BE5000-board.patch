From 4f4a2bd2cb4a7c30c25f85d04b7d891dc21b8a12 Mon Sep 17 00:00:00 2001
From: Ray Liu <ray.xy.liu@gmail.com>
Date: Sun, 10 May 2026 12:13:21 +0800
Subject: [PATCH] arm: airoha: add Xiaomi BE5000 board for AN7563

Add the Xiaomi BE5000 board files for the AN7563 target.  The board
uses the AN7563 legacy single-FIP boot flow, raw SPI-NAND layout and
BMT-aware flash handling, with a dedicated device tree and defconfig
for its board identity.

Signed-off-by: Ray Liu <ray.xy.liu@gmail.com>
---
 arch/arm/dts/an7563-xiaomi-be5000.dts     |  79 ++++++++++++++++++
 configs/an7563_xiaomi_be5000_defconfig   |  75 +++++++++++++++++
 2 files changed, 154 insertions(+)
 create mode 100644 arch/arm/dts/an7563-xiaomi-be5000.dts
 create mode 100644 configs/an7563_xiaomi_be5000_defconfig

diff --git a/arch/arm/dts/an7563-xiaomi-be5000.dts b/arch/arm/dts/an7563-xiaomi-be5000.dts
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/arch/arm/dts/an7563-xiaomi-be5000.dts
@@ -0,0 +1,79 @@
+// SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+/dts-v1/;
+
+/* Bootloader installs ATF here (BL31 resident region, ~256 KiB). */
+/memreserve/ 0x80000000 0x88000;
+
+#include "an7563.dtsi"
+
+/ {
+	model = "Xiaomi BE5000";
+	compatible = "xiaomi,be5000", "airoha,an7563", "airoha,en7581";
+
+	aliases {
+		serial0 = &uart1;
+	};
+
+	chosen {
+		bootargs = "console=ttyS0,115200 earlycon";
+		stdout-path = "serial0:115200n8";
+	};
+
+	memory@80000000 {
+		device_type = "memory";
+		reg = <0x80000000 0x20000000>;
+	};
+};
+
+&gpio0 {
+	status = "okay";
+};
+
+&gpio1 {
+	status = "okay";
+};
+
+&pcie0 {
+	status = "okay";
+};
+
+&pcie1 {
+	status = "okay";
+};
+
+&snfi {
+	status = "okay";
+};
+
+&spi_nand {
+	airoha,bmt;
+
+	partitions {
+		compatible = "fixed-partitions";
+		#address-cells = <1>;
+		#size-cells = <1>;
+
+		partition@0 {
+			label = "u-boot";
+			reg = <0x0 0x7c000>;
+			read-only;
+		};
+
+		partition@1 {
+			label = "u-boot-env";
+			reg = <0x7c000 0x4000>;
+		};
+
+		partition@2 {
+			label = "art";
+			reg = <0x80000 0x40000>;
+			read-only;
+		};
+
+		partition@3 {
+			compatible = "denx,fit";
+			label = "firmware";
+			reg = <0xc0000 0x4000000>;
+		};
+	};
+};
diff --git a/configs/an7563_xiaomi_be5000_defconfig b/configs/an7563_xiaomi_be5000_defconfig
new file mode 100644
index 0000000..2222222
--- /dev/null
+++ b/configs/an7563_xiaomi_be5000_defconfig
@@ -0,0 +1,75 @@
