From c873c5b388f07701dda80e3e159266fa9c183893 Mon Sep 17 00:00:00 2001
From: Chen Minqiang <ptpt52@gmail.com>
Date: Sat, 4 Apr 2026 06:37:04 +0800
Subject: [PATCH] mtd: spinand: Add support for UNIM UM19A0HISW

Add support for the UNIM UM19A0HISW 1Gb SPI NAND flash memory chip
(Manufacturer ID: 0xB0, Device ID: 0x14).

This chip features a 2048-byte page size, 64-byte OOB size, and
64 pages per block (128KB block size).

Key implementation details based on the device datasheet:
- Read Opcodes: Excluded SPINAND_PAGE_READ_FROM_CACHE_QUADIO_OP (0xEB)
  and DUALIO_OP (0xBB) as they are not supported by the hardware.
  Safely relies on X4_OP (0x6B) and X2_OP (0x3B) for multi-I/O reads.
- OOB Layout: The internal ECC parity bytes are stored in a hardware-
  hidden spare area. This allows exposing 62 bytes of the 64-byte OOB
  as free space for the filesystem, reserving only the first 2 bytes
  (offset 0 and 1) for the Bad Block Marker (BBM).
- ECC Status: Parses the 3-bit ECC status from the Status Register
  bits [6:4]. This provides granular reporting of corrected bitflips
  (mapping to 3, 6, or 8 bits to trigger MTD data refreshment when
  necessary) and correctly identifies uncorrectable errors (-EBADMSG).

Signed-off-by: Chen Minqiang <ptpt52@gmail.com>
---
 drivers/mtd/nand/spi/Makefile |  2 +-
 drivers/mtd/nand/spi/core.c   |  1 +
 drivers/mtd/nand/spi/unim.c   | 91 +++++++++++++++++++++++++++++++++++
 include/linux/mtd/spinand.h   |  1 +
 4 files changed, 94 insertions(+), 1 deletion(-)
 create mode 100644 drivers/mtd/nand/spi/unim.c

diff --git a/drivers/mtd/nand/spi/Makefile b/drivers/mtd/nand/spi/Makefile
index 65378c4c8..9f7bd6309 100644
--- a/drivers/mtd/nand/spi/Makefile
+++ b/drivers/mtd/nand/spi/Makefile
@@ -1,4 +1,4 @@
 # SPDX-License-Identifier: GPL-2.0
 spinand-objs := core.o alliancememory.o ato.o esmt.o etron.o fidelix.o fmsh.o foresee.o gigadevice.o
-spinand-objs += macronix.o micron.o paragon.o skyhigh.o toshiba.o winbond.o xtx.o
+spinand-objs += macronix.o micron.o paragon.o skyhigh.o toshiba.o winbond.o xtx.o unim.o
 obj-$(CONFIG_MTD_SPI_NAND) += spinand.o
diff --git a/drivers/mtd/nand/spi/core.c b/drivers/mtd/nand/spi/core.c
index d450dc8cd..235f01138 100644
--- a/drivers/mtd/nand/spi/core.c
+++ b/drivers/mtd/nand/spi/core.c
@@ -1199,6 +1199,7 @@ static const struct spinand_manufacturer *spinand_manufacturers[] = {
 	&toshiba_spinand_manufacturer,
 	&winbond_spinand_manufacturer,
 	&xtx_spinand_manufacturer,
+	&unim_spinand_manufacturer,
 };
 
 static int spinand_manufacturer_match(struct spinand_device *spinand,
diff --git a/drivers/mtd/nand/spi/unim.c b/drivers/mtd/nand/spi/unim.c
new file mode 100644
index 000000000..84f0cbbce
--- /dev/null
+++ b/drivers/mtd/nand/spi/unim.c
@@ -0,0 +1,91 @@
+// SPDX-License-Identifier: GPL-2.0
+#include <linux/module.h>
+#include <linux/mtd/spinand.h>
+
+#define SPINAND_MFR_UNIM 0xB0
+
+static SPINAND_OP_VARIANTS(unim_read_cache_variants,
+                           SPINAND_PAGE_READ_FROM_CACHE_X4_OP(0, 1, NULL, 0),
+                           SPINAND_PAGE_READ_FROM_CACHE_X2_OP(0, 1, NULL, 0),
+                           SPINAND_PAGE_READ_FROM_CACHE_OP(true, 0, 1, NULL, 0),
+                           SPINAND_PAGE_READ_FROM_CACHE_OP(false, 0, 1, NULL, 0));
+
+static SPINAND_OP_VARIANTS(unim_write_cache_variants,
+                           SPINAND_PROG_LOAD_X4(true, 0, NULL, 0),
+                           SPINAND_PROG_LOAD(true, 0, NULL, 0));
+
+static SPINAND_OP_VARIANTS(unim_update_cache_variants,
+                           SPINAND_PROG_LOAD_X4(false, 0, NULL, 0),
+                           SPINAND_PROG_LOAD(false, 0, NULL, 0));
+
+static int unim_ooblayout_ecc(struct mtd_info *mtd, int section,
+                              struct mtd_oob_region *region)
+{
+	return -ERANGE;
+}
+
+static int unim_ooblayout_free(struct mtd_info *mtd, int section,
+                               struct mtd_oob_region *region)
+{
+	if (section)
+		return -ERANGE;
+
+	region->offset = 2;
+	region->length = 62;
+
+	return 0;
+}
+
+static const struct mtd_ooblayout_ops unim_ooblayout = {
+	.ecc = unim_ooblayout_ecc,
+	.free = unim_ooblayout_free,
+};
+
+static int unim_ecc_get_status(struct spinand_device *spinand, u8 status)
+{
+	u8 ecc_status = (status & 0x70) >> 4;
+
+	switch (ecc_status) {
+	case 0x00:
+		return 0;
+	case 0x01:
+		return 3;
+	case 0x03:
+		return 6;
+	case 0x05:
+		return 8;
+	case 0x02:
+		return -EBADMSG;
+	default:
+		return -EBADMSG;
+	}
+}
+
+static const struct spinand_info unim_spinand_table[] = {
+	SPINAND_INFO("UM19A0HISW",
+	             SPINAND_ID(SPINAND_READID_METHOD_OPCODE_DUMMY, 0x14),
+	             NAND_MEMORG(1, 2048, 64, 64, 1024, 20, 1, 1, 1),
+	             NAND_ECCREQ(8, 512),
+	             SPINAND_INFO_OP_VARIANTS(
+	                 &unim_read_cache_variants,
+	                 &unim_write_cache_variants,
+	                 &unim_update_cache_variants
+	             ),
+	             SPINAND_HAS_QE_BIT,
+	             SPINAND_ECCINFO(
+	                 &unim_ooblayout,
+	                 unim_ecc_get_status
+	             ),
+	            ),
+};
+
+static const struct spinand_manufacturer_ops unim_spinand_manuf_ops = {
+};
+
+const struct spinand_manufacturer unim_spinand_manufacturer = {
+	.id = SPINAND_MFR_UNIM,
+	.name = "Unim",
+	.chips = unim_spinand_table,
+	.nchips = ARRAY_SIZE(unim_spinand_table),
+	.ops = &unim_spinand_manuf_ops,
+};
diff --git a/include/linux/mtd/spinand.h b/include/linux/mtd/spinand.h
index d08696ec3..794caf2d0 100644
--- a/include/linux/mtd/spinand.h
+++ b/include/linux/mtd/spinand.h
@@ -276,6 +276,7 @@ extern const struct spinand_manufacturer skyhigh_spinand_manufacturer;
 extern const struct spinand_manufacturer toshiba_spinand_manufacturer;
 extern const struct spinand_manufacturer winbond_spinand_manufacturer;
 extern const struct spinand_manufacturer xtx_spinand_manufacturer;
+extern const struct spinand_manufacturer unim_spinand_manufacturer;
 
 /**
  * struct spinand_op_variants - SPI NAND operation variants
-- 
2.17.1

